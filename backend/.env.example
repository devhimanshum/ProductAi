# ─────────────────────────────────────────────
# ProductAI Backend — Environment Variables
# ─────────────────────────────────────────────

# Your OpenAI API key (required)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI model to use (gpt-4o is recommended for best accuracy)
OPENAI_MODEL=gpt-4o

# Port for the Express server
PORT=3001

# Allowed frontend origin for CORS (use * for all, or specify your frontend URL)
CORS_ORIGIN=*
